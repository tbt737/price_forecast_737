# ──────────────────────────────────────────────────────────────────────────────
# Multi-Commodity Quant Forecasting Platform — environment template
#
# Copy this file to `.env` and fill in values LOCALLY. Never commit `.env`.
# All values here are intentionally BLANK — no real secrets belong in this repo.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (consumed by docker-compose.yml and the API/ETL layers) ─────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
# Full SQLAlchemy URL (derive from the parts above), e.g.
# postgresql+psycopg://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=

# ── API service (FastAPI) ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
API_SECRET_KEY=
LOG_LEVEL=info

# ── Web frontend (Next.js) ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── ETL / data-source credentials (fill only what you actually use) ───────────
# Market data
ICE_API_KEY=
BARCHART_API_KEY=
NASDAQ_DATA_LINK_API_KEY=
YFINANCE_USER_AGENT=

# Weather
NASA_POWER_API_KEY=
COPERNICUS_CDS_API_KEY=
NOAA_API_TOKEN=

# Macro / fundamentals
FRED_API_KEY=
USDA_QUICKSTATS_API_KEY=
WORLD_BANK_API_KEY=

# Logistics / freight
DREWRY_API_KEY=
FREIGHTOS_API_KEY=

# News / events
NEWS_API_KEY=
GDELT_API_KEY=

# ── Storage / paths (relative to repo root) ────────────────────────────────────
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_EXPORTS_DIR=data/exports
MODEL_REGISTRY_DIR=ml/registry
